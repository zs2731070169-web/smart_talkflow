# ============================================================================
# smart_talkflow 本地环境配置(.env 模板)
# 用法:cp .env.example .env,按需修改。docker compose 会自动读取同目录下的 .env。
# ============================================================================

# ---- MySQL 连接----
MYSQL_HOST=127.0.0.1
# 对外暴露的宿主机端口(容器内固定 3306)。若本机 3306 已被占用,改为 3307 等。
MYSQL_PORT=3306
# 业务数据库(建表脚本会在此库下创建表)
MYSQL_DATABASE=smart_talkflow
# 应用连接用的账号和密码(必填,缺失启动即报错)
MYSQL_USER=talkflow
MYSQL_PASSWORD=talkflow
# root 密码:仅供 docker-compose 初始化 MySQL 容器使用,应用代码不读取。
MYSQL_ROOT_PASSWORD=root
# 容器时区(应用时区也读此变量)
TZ=Asia/Shanghai
# 连接池初始大小
POOL_SIZE=10
# 连接池最大大小
MAX_SIZE=20
# 连接最长存活秒数,主动回收避免被 wait_timeout 断开
KEEP_ALIVE=3600
# 生产关闭 SQL 日志; 本地调试可置 True
SQL_LOG=True

# ---- LLM 配置----
# 模型提供商
LLM_PROVIDER=openai
# 模型的api key
LLM_API_KEY=你的API_KEY
# 模型api
LLM_BASE_URL=https://api.openai.com/v1
# 模型请求超时时间
LLM_TIMEOUT=60
# 意图理解模型名称
INTENT_LLM_NAME=gpt-4o
# 意图理解模型温度
INTENT_LLM_TEMPERATURE=0.3
# 意图理解模型输出最大token
INTENT_LLM_MAX_TOKENS=4096
# 生成回复模型名称
REPLY_LLM_NAME=gpt-4o-mini
# 生成回复模型温度
REPLY_LLM_TEMPERATURE=0
# 生成回复模型输出最大token
REPLY_LLM_MAX_TOKENS=4096

# ---- 提示词仓库(可选,从远程 git 仓库拉取系统提示词)----
# 是否启用远程仓库拉取(False 时直接用本地默认/自定义提示词)
IS_GIT_REPO=False
# 远程提示词仓库地址
GIT_REPO_URL=
# 要拉取的分支,留空使用仓库默认分支
GIT_BRANCH=

# intent / reply 阶段各自的远程路径(留空时按阶段默认 intent_system_prompt.md / reply_system_prompt.md)
GIT_INTENT_RELATIVE_PATH=
GIT_REPLY_RELATIVE_PATH=
# ---- 下游业务系统(OA)----
# 下游业务系统基地址
OA_BASE_URL=your-base-url
# api-key:服务账号标识
# PYTHONPATH=src python -m utils.api_key_util   # 生成 api-key(明文)+ api-key-hash
OA_API_KEY=your-agent-api-key
# delegation-secret:与下游服务共享的 HMAC 签名密钥(防伪造 operator)
# python -c "import secrets; print(secrets.token_urlsafe(32))"  再单独生成 delegation-secret
OA_DELEGATION_SECRET=your-delegation-secret

# ---- 认证模式----
# 开发态(True):信任请求头 X-Operator-* 作为操作人,便于本地联调。
# 生产置 False 走 SSO(JWT/OIDC)解析。
AUTH_DEV_MODE=True

# ---- Redis----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- SSO(生产态 AUTH_DEV_MODE=False 时必填)----
# JWT issuer(公钥颁发者)
SSO_ISSUER=smart_sso
# JWKS 公钥端点
SSO_JWKS_URI=http://localhost:48081/.well-known/jwks.json
# JWT audience 使用范围校验(留空则不校验)
SSO_AUDIENCE=
# JWKS redis 缓存秒数
SSO_JWKS_CACHE_TTL=3600

# ---- 心跳存活检测 + 失联工作流自动重跑 ----
# 心跳超时
PROCESS_HEARTBEAT_TIMEOUT=60
# watchdog 扫描间隔秒
PROCESS_RECOVERY_INTERVAL=20
